MAAS_API_KEY=sk-xxxx
MAAS_BASE_URL=https://llm-6xhzf2xp8v12jath.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
TEXT_MODEL=qwen3.7-max
IMAGE_MODEL=qwen-image-2.0-pro-2026-06-22
# 视频分析模块用：全模态（omni）模型，接收图片帧 + 音频段。走 MAAS_BASE_URL + MAAS_API_KEY。
VIDEO_MODEL=qwen3.7-plus
PORT=8787
DASHSCOPE_BASE_URL=https://your-endpoint.maas.aliyuncs.com/api/v1

# 绘本打卡模块用：阿里百炼 DashScope 原生接口 Key（https://bailian.console.aliyun.com 获取）
DASHSCOPE_API_KEY=sk-xxxx

# 游戏语音（听声音猜动物）：走 DASHSCOPE_BASE_URL + MAAS_API_KEY 的 qwen-tts。
# 以下可选，不配则用默认。音色可选 Cherry(活泼女声)/Chelsie/Ethan/Serena 等。
# TTS_MODEL=qwen-tts
# TTS_VOICE=Cherry

# 数据库驱动：sqlite（默认，本地文件 lessons.db，无需额外配置）| mysql（需要下面几项）
DB_DRIVER=sqlite
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
